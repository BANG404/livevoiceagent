# LLM used by the LangChain visitor-registration agent.
AGENT_MODEL=qwen3.5-omni-flash
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=sk-your-dashscope-api-key

# FastAPI voice server calls the LangGraph dev/server API with langgraph_sdk.
LANGGRAPH_API_URL=http://127.0.0.1:2024
LANGGRAPH_API_KEY=
LANGGRAPH_ASSISTANT_ID=agent

# Public HTTPS base URL exposed to Twilio, for example an ngrok URL.
PUBLIC_BASE_URL=https://example.ngrok-free.app

# Enterprise WeChat group robot webhook used to notify guards.
GUARD_WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...

# Local voice stack. Use a multimodal AGENT_MODEL that supports audio input,
# or add STT before using a text-only local chat model.
TTS_PROVIDER=kokoro
KOKORO_LANG_CODE=z
KOKORO_REPO_ID=hexgrad/Kokoro-82M
AGENT_VOICE=zf_xiaoxiao
VAD_PROVIDER=silero
SILERO_VAD_THRESHOLD=0.5
SILERO_VAD_MIN_SILENCE_MS=350

# Local JSONL audit store.
VISITOR_STORE_PATH=data/visitors.jsonl
PARK_NAME=工业园区

# Optional but recommended for tracing.
LANGSMITH_API_KEY=lsv2_...
