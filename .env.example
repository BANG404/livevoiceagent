# LLM used by the LangChain visitor-registration agent.
ANTHROPIC_API_KEY=your-anthropic-api-key
AGENT_MODEL=anthropic:claude-sonnet-4-6

# Public HTTPS base URL exposed to Twilio, for example an ngrok URL.
PUBLIC_BASE_URL=https://example.ngrok-free.app

# Enterprise WeChat group robot webhook used to notify guards.
GUARD_WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...

# Speech-to-text adapter. TTS defaults to a silence stub until Kokoro is wired.
OPENAI_API_KEY=your-openai-api-key
STT_MODEL=gpt-4o-mini-transcribe
TTS_PROVIDER=kokoro
KOKORO_LANG_CODE=z
AGENT_VOICE=zf_001

# Local JSONL audit store.
VISITOR_STORE_PATH=data/visitors.jsonl
PARK_NAME=工业园区

# Optional but recommended for tracing.
LANGSMITH_API_KEY=lsv2_...
